# YaoYan AI Platform - Environment Variables
# Copy this file to .env and modify as needed

# ===========================================
# Database Configuration (使用 RAGForge PostgreSQL)
# ===========================================
# Docker 容器内通过 host.docker.internal 访问宿主机
DATABASE_URL=postgresql+asyncpg://kb:kb@host.docker.internal:5435/yaoyan
DB_HOST=host.docker.internal
DB_PORT=5435
DB_USER=kb
DB_PASSWORD=kb
DB_NAME=yaoyan

# ===========================================
# Backend Configuration
# ===========================================
BACKEND_PORT=3002

# JWT Configuration (CHANGE IN PRODUCTION!)
JWT_SECRET_KEY=yaoyan-jwt-secret-key-2026

# API Key Encryption (MUST be exactly 32 characters!)
API_KEY_ENCRYPTION_KEY=your-aes-key-32-bytes-long!!

# ===========================================
# RAGForge Configuration
# ===========================================
RAGFORGE_BASE_URL=http://192.168.168.105:8020
RAGFORGE_ADMIN_KEY=your-ragforge-admin-key

# ===========================================
# Frontend Configuration
# ===========================================
FRONTEND_PORT=5173
